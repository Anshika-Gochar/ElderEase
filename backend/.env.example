# ── Server configuration ──
NODE_ENV=development
PORT=5000

# ── MongoDB Configuration ──
# Connection URI for your MongoDB Atlas cluster.
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://your-db-user:your-db-password@cluster0.xxxxx.mongodb.net/test

# ── Redis Configuration ──
# Redis connection URL. Used for caching in production.
# Leaves empty to fall back to memory-store in development.
REDIS_URL=redis://localhost:6379

# ── Authentication ──
# Secret key used for signing JWT tokens. Use a cryptographically strong string.
JWT_SECRET=your-jwt-secret-key-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# ── Firebase Admin SDK (Cloud Messaging & Auth) ──
# Required for push notifications.
# Get these credentials from your Firebase Console under Project Settings -> Service Accounts.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com

# ── Twilio (SMS & Voice Calls) ──
# Get SID and Token from Twilio Console (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_ENABLE_VOICE=false

# ── SendGrid (Email dispatch) ──
# Get API key from SendGrid Console -> Settings -> API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=your-verified-sendgrid-sender-email@domain.com

# ── Microservices & Client URL Configuration ──
# URL of the AI FastAPI microservice
AI_SERVICE_URL=http://localhost:8000

# Client apps URLs for CORS mapping and token verification redirect
CLIENT_ELDER_URL=http://localhost:5173
CLIENT_CAREGIVER_URL=http://localhost:5174

# Production Vercel deployment URLs (Task 8 CORS config)
ELDER_APP_URL=https://elderease-elder.vercel.app
CAREGIVER_APP_URL=https://elderease-caregiver.vercel.app
