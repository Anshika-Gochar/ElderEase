# ── API & WebSockets ──
# Base URL of the deployed Express backend service.
# Use http://localhost:5000/api for local development proxy.
# Use the Railway URL for production (e.g. https://your-backend.up.railway.app/api)
VITE_API_URL=http://localhost:5000/api

# WebSocket URL of the deployed Express backend service (no /api prefix).
# Use http://localhost:5000 for local development.
# Use the Railway URL for production (e.g. https://your-backend.up.railway.app)
VITE_SOCKET_URL=http://localhost:5000

# ── Firebase configuration ──
# Get these values from Firebase Console -> Project Settings -> General -> Web Apps -> CDN/Config
VITE_FIREBASE_API_KEY=AIzaSyAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_VAPID_KEY=your-firebase-vapid-public-key
